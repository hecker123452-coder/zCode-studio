// Prisma schema — uses SQLite locally, falls back to memory DB on serverless
// On Vercel: DATABASE_URL is not set → Prisma generate still works (schema only)
// Runtime: db.ts checks isPrismaAvailable → falls back to memoryDB

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DeployedProject {
  id        String   @id
  html      String
  fileName  String
  title     String
  views     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
